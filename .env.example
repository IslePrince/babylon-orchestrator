# ─────────────────────────────────────────────────────────────
# Babylon Studio Orchestrator — Environment Configuration
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your API keys.
# NEVER commit .env to git. It is in .gitignore.
# ─────────────────────────────────────────────────────────────

# ── Anthropic Claude ─────────────────────────────────────────
# Used for: story ingest, world bible, screenplay, cinematographer,
#           asset manifest building
# Get key: https://console.anthropic.com/
# Cost tier: cheap (~$0.01-0.15 per chapter pass)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── ElevenLabs ───────────────────────────────────────────────
# Used for: voice generation (dialogue audio)
# Get key: https://elevenlabs.io/app/settings/api-keys
# Cost tier: medium (~$0.30 per 1000 characters)
# NOTE: Assign voice IDs to characters via the Voice Casting
#       page in the UI before running the audio stage.
ELEVENLABS_API_KEY=your-key-here

# ── Meshy.ai ─────────────────────────────────────────────────
# Used for: 3D mesh generation (environments, props, costumes)
#           AND animation for background characters
# Get key: https://www.meshy.ai/settings
# Cost tier: medium-high ($0.10-$0.50 per asset by detail level)
MESHY_API_KEY=your-key-here

# ── Cartwheel ────────────────────────────────────────────────
# Used for: body animation for NAMED characters only
#           (background characters use Meshy animation instead)
# Get key: https://getcartwheel.com/
# Cost tier: medium (~$0.15 per motion clip)
CARTWHEEL_API_KEY=your-key-here

# ── Stability AI ─────────────────────────────────────────────
# Used for: storyboard placeholder images only (NOT final art)
# Get key: https://platform.stability.ai/account/keys
# Cost tier: very cheap (~$0.08 per shot pair, 16:9 + 9:16)
STABILITY_API_KEY=your-key-here

# ── Optional: default projects directory ─────────────────────
# If set, the UI server uses this as the default --projects-dir
# Can be overridden by passing --projects-dir on the command line
# DEFAULT_PROJECTS_DIR=/Users/yourname/studio/projects
