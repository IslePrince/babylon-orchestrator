__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/
*.egg

# Virtual environments
venv/
env/
.venv/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Node (for docx tooling)
node_modules/

# Test outputs
*.test.docx
tmp/
temp/

# OS
.DS_Store
.AppleDouble
.LSOverride

# Runtime logs (stage execution output)
logs/

# Claude Code dev-local (preview-browser launch config)
.claude/
